# ── Large data / raw captures ────────────────────────────────────────────────
scenes/*/raw/
scenes/*/processed/
scenes/*/nerfstudio_data/
scenes/*/nerfstudio_outputs/
scenes/*/exports/
scenes/*.zip
scenes/*.z01
scenes/*.z02
scenes/*.z03
scenes/*.z04
scenes/*.z05

# All image files in scenes are large — never commit them
scenes/**/*.JPG
scenes/**/*.jpg
scenes/**/*.jpeg
scenes/**/*.JPEG
scenes/**/*.png
scenes/**/*.PNG
scenes/**/*.heic
scenes/**/*.HEIC
scenes/**/*.db

# Keep the pre-baked COLMAP sparse text files and validation metrics
!scenes/gerrard-hall/gerrard-hall/sparse/
!scenes/gerrard-hall/metrics/

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
env/
*.egg-info/

# ── Node / Web ───────────────────────────────────────────────────────────────
web/node_modules/
web/dist/

# ── Nerfstudio / ML outputs ──────────────────────────────────────────────────
outputs/
nerfstudio_outputs/
*.ckpt
*.pt
*.pth
wandb/

# ── Splat files (large — host externally, don't commit) ──────────────────────
*.ply
*.splat
web/public/*.ply
web/public/*.splat

# ── OS / Editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# ── Experiment manifest (fill-in manually, not for source control) ───────────
experiments.json

# -- SOTA runs ───────────────────────────────────────────────────────────────
sota_run_results/inria_3dgs/
sota_run_results/mip_splatting/
sota_run_results/splatfacto/
